<section>
  <h2>Contacto</h2>

  <form action="/contact" method="POST">
    <label>Nombre:</label>
    <input type="text" name="nombre" required>

    <label>Email:</label>
    <input type="email" name="email" required>

    <label>Mensaje:</label>
    <textarea name="mensaje" required></textarea>

    <button type="submit">Enviar</button>
  </form>
</section>